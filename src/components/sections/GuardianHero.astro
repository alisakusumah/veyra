---
/**
 * GuardianHero
 * Primary Veyra identity surface for Alisa Kusumah.
 *
 * Mamah Sachan / Mamah Sichan guardrail:
 * the guardian visual should feel alive and protective, but never noisy.
 */
interface Props {
  profile: {
    name: string;
    eyebrow: string;
    tagline: string;
    builder: string;
    season: string;
    network: { name: string; chainId: string; contractStatus: string; contractAddress: string };
    links: { demoUrl: string; repositoryUrl: string };
  };
}

const { profile } = Astro.props;

// --- ON-CHAIN VERIFICATION (ZERO-JS CLIENT SIDE, EXECUTED AT BUILD TIME) ---
let isVerified = false;

try {
  const response = await fetch("https://testnet-rpc.iopn.tech", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      jsonrpc: "2.0",
      method: "eth_call",
      params: [{
        to: profile.network.contractAddress,
        data: "0xc395f857" // keccak256("repositoryUrl()")
      }, "latest"],
      id: 1
    })
  });
  
  const rpcData = await response.json();
  
  if (rpcData.result && rpcData.result !== "0x") {
    // Decode ABI string manually (Zero dependencies!)
    const hex = rpcData.result.slice(2);
    const length = parseInt(hex.slice(64, 128), 16);
    const stringHex = hex.slice(128, 128 + length * 2);
    
    let onChainRepo = "";
    for (let i = 0; i < stringHex.length; i += 2) {
      onChainRepo += String.fromCharCode(parseInt(stringHex.substring(i, i + 2), 16));
    }
    
    if (onChainRepo === profile.links.repositoryUrl) {
      isVerified = true;
    }
  }
} catch (e) {
  console.error("Failed to verify contract on-chain:", e);
}
---

<section class="hero-stage" aria-labelledby="veyra-title">
  <div class="topline" aria-label="Veyra status">
    <span class="brand-mini">VEYRA</span>
    <span class="topline-divider"></span>
    <span>{profile.builder}</span>
    <span class="topline-dot" aria-hidden="true"></span>
    <span>{profile.network.name}</span>
  </div>

  <div class="hero-grid">
    <aside class="guardian-frame" aria-label="Veyra guardian visual">
      <div class="frame-aura" aria-hidden="true"></div>
      <video
        class="guardian-video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/media/veyra-guardian-poster.webp"
      >
        <source src="/media/veyra-guardian-loop.mp4" type="video/mp4" />
      </video>
      <div class="guardian-overlay" aria-hidden="true"></div>
      <div class="scanline" aria-hidden="true"></div>
      <div class="guardian-caption">
        <span>Guardian Seal</span>
        <strong>{profile.builder}</strong>
      </div>
    </aside>

    <div class="hero-copy">
      <p class="micro-label">{profile.eyebrow}</p>
      
      <h1 id="veyra-title" class="veyra-title">
        <span class="veyra-title__text">{profile.name}</span>
        {isVerified && (
          <span class="verified-icon-badge" title="Cryptographically Verified on OPN Chain" aria-label="On-Chain Verified">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L3 7V11C3 16.55 6.84 21.74 12 23C17.16 21.74 21 16.55 21 11V7L12 2Z" fill="currentColor" fill-opacity="0.15" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8 12L11 15L16 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        )}
      </h1>
      
      <p class="hero-tagline">{profile.tagline}</p>

      <div class="identity-chips" aria-label="Veyra metadata summary">
        <span>{profile.season}</span>
        <span>Chain ID {profile.network.chainId}</span>
        <span>{profile.network.contractStatus}</span>
      </div>

      <p class="hero-note">
        {isVerified 
          ? `A premium sovereign identity layer for ${profile.builder}. This profile is cryptographically verified against the deployed registry on OPN Testnet.`
          : `A premium identity layer for ${profile.builder}. Contract references stay pending until a real OPN Testnet deployment exists.`
        }
      </p>

      <div class="hero-actions" aria-label="Action buttons">
        <a 
          href={`https://vercel.com/new/clone?repository-url=${encodeURIComponent(profile.links.repositoryUrl)}`}
          target="_blank" 
          rel="noopener noreferrer"
          class="veyra-btn veyra-btn-primary"
        >
          Deploy Veyra
        </a>
        <a 
          href={profile.links.repositoryUrl}
          target="_blank" 
          rel="noopener noreferrer"
          class="veyra-btn veyra-btn-secondary"
        >
          View Source
        </a>
      </div>
    </div>
  </div>
</section>
