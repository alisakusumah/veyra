# ==============================================================================
# VEYRA - SECURITY & ENVIRONMENT CONFIGURATION
# ==============================================================================
# ⚠️ CYBERSECURITY WARNING:
# NEVER commit your actual .env file to public version control.
# NEVER share your PRIVATE_KEY with anyone.
# This template is provided for reference only.
# ==============================================================================

# 1. NETWORK RPC
# Provide the RPC URL for the OPN Testnet.
OPN_TESTNET_RPC="https://testnet-rpc.iopn.tech"

# 2. DEPLOYER PRIVATE KEY
# The private key of the builder wallet. (e.g., Alisa Kusumah's deployment wallet)
# It is recommended to use a hardware wallet or a strictly isolated hot wallet.
# DO NOT PREFIX WITH 0x.
OPN_TESTNET_PRIVATE_KEY="your_private_key_here_keep_it_safe"
